{
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "rewrites": [
      { "source": "/api/(.*)", "destination": "/api/$1" },
      { "source": "/sites/:siteId/:path*", "destination": "/api/sites/:siteId/:path*" },
      { "source": "/sites/:siteId", "destination": "/api/sites/:siteId/" },
      { "source": "/(.*)", "destination": "/index.html" }
    ]
  }